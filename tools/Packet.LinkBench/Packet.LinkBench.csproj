<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <!-- Bench tool, not for shipping. Relax analyzer-as-error so we can iterate fast. -->
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Packet.Core\Packet.Core.csproj" />
    <ProjectReference Include="..\..\src\Packet.Ax25\Packet.Ax25.csproj" />
    <ProjectReference Include="..\..\src\Packet.Kiss\Packet.Kiss.csproj" />
    <!-- AxudpFrameTransport (rung-1 cross-check) + PacingKissModem (ackmode pacing, via InternalsVisibleTo). -->
    <ProjectReference Include="..\..\src\Packet.Node.Core\Packet.Node.Core.csproj" />
  </ItemGroup>

</Project>
