<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <!-- Fuzz tool — relax analyzer-as-error so we can iterate fast. -->
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SharpFuzz" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Packet.Ax25\Packet.Ax25.csproj" />
    <ProjectReference Include="..\..\src\Packet.Kiss\Packet.Kiss.csproj" />
    <ProjectReference Include="..\..\src\Packet.Core\Packet.Core.csproj" />
    <!-- Node console command parser — the node-host slice-1 fuzz target. -->
    <ProjectReference Include="..\..\src\Packet.Node.Core\Packet.Node.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="corpus\**\*" CopyToOutputDirectory="PreserveNewest" />
    <None Include="FINDINGS.md" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
