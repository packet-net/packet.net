{
  "name": "ax25sdl",
  "version": "0.2.1",
  "description": "AX.25 v2.2 SDL specification as TypeScript data structures, generated from the canonical SDL figure transcriptions in M0LTE/packet.net.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/M0LTE/packet.net.git",
    "directory": "ts-spec"
  },
  "homepage": "https://github.com/M0LTE/packet.net/tree/main/ts-spec",
  "bugs": {
    "url": "https://github.com/M0LTE/packet.net/issues"
  },
  "type": "module",
  "main": "dist/ax25sdl/index.js",
  "types": "dist/ax25sdl/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ax25sdl/index.d.ts",
      "default": "./dist/ax25sdl/index.js"
    }
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run"
  },
  "keywords": [
    "ax25",
    "amateur-radio",
    "ham-radio",
    "packet-radio",
    "sdl",
    "state-machine",
    "codegen"
  ],
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
