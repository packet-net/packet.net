; RHPv2 wire grammar — PWP-0222 / PWP-0245, as observed on the live XRouter wire.
;
; This CDDL (RFC 8610) file is the machine-readable, language-neutral definition
; of the RHPv2 JSON-over-TCP message shapes. It is the conformance oracle: any
; implementation's emitted JSON that fails to validate against this grammar has
; drifted from the wire contract.
;
; Scope: the DAPPS-proven subset (R-1 through R-7) — the full message surface
; pdn's RhpServer emits. Deferred families/modes (netrom, inet, unix, raw,
; trace, seqpkt, semiraw) are not yet pinned here.
;
; ─── Spec deltas (PWP-0222 text vs live XRouter wire vs this grammar) ─────────
;
; This grammar encodes the LIVE WIRE (XRouter 505c + RHPTEST 505d), not the
; spec's prose. Where they differ, the wire wins and the delta is recorded here
; and in docs/rhp2-server.md's tables. Known deltas:
;
; WIRE-FIDELITY (grammar matches XRouter, spec text differs):
;   WF-1  errCode/errText casing: spec field tables say lowercase "errcode"/
;         "errtext"; live XRouter emits capital "errCode"/"errText" on EVERY
;         reply. (Note: the spec's own authReply EXAMPLE uses capitals too —
;         the field tables are the inconsistent part.)
;   WF-2  connectReply type: spec §3.20 says "ConnectReply" (PascalCase);
;         live XRouter emits "connectReply" (camelCase).
;   WF-3  accept.port type: spec says integer; live XRouter sends a string.
;   WF-4  open.port type: spec field table says string, but the spec's own
;         OPEN example uses "port": 2 (a JSON number). Grammar accepts both.
;   WF-8  errCode 17: not in the spec's error table (0–16); XRouter-observed.
;   WF-16 TRACE recv fields tseq/ilen/pid/ptcl: not in the spec at all;
;         XRouter-observed (the spec's TRACE example shows srce/dest/ctrl/
;         frametype/rseq/cr/pf but omits these four).
;
; SPEC OMISSIONS (fields the spec doesn't define but XRouter requires):
;   SO-1  bind.handle: spec §3.15 lists only type/id/local/port — no handle.
;         XRouter's BIND requires a handle (otherwise it can't identify the
;         socket). The BSD path (SOCKET→BIND→LISTEN→CONNECT) is described but
;         the handle was never added to BIND/LISTEN/CONNECT definitions.
;   SO-2  listen.handle: spec §3.17 lists only type/id/flags — no handle.
;   SO-3  connect.handle: spec §3.19 lists only type/id/remote — no handle.
;
; PERMISSIVENESS (grammar is more lenient than the spec's "all fields mandatory
; unless otherwise stated" rule):
;   P-1  open.flags: spec says mandatory; absent = 0 (passive) is the natural
;        default and XRouter accepts it. Grammar makes it optional.
;   P-2  open.port: spec says mandatory; XRouter accepts absent (defaults to
;        first port outbound / all ports for bind). Grammar makes it optional.
;   P-3  sendto.port: spec says mandatory; XRouter accepts absent when the
;        socket is already bound to a port. Grammar makes it optional.
;   P-4  sendto.remote: spec says mandatory; spec text (§3.21) says "if a
;        local address is bound, only the remote address need be supplied and
;        vice versa" — implying either can be absent. Grammar makes it optional.
;   P-5  errText on replies: spec says mandatory; XRouter omits it on some
;        success replies (errCode 0). Grammar makes it optional.
;
; NAMED DEVIATIONS (pdn deliberately differs from XRouter — see D1–D10 in
; docs/rhp2-server.md):
;   D8   open.local: spec says mandatory, XRouter requires it (errCode 6
;        without it); pdn accepts absent and defaults to the node callsign.
;
; Framing (not in this grammar): 2-byte big-endian length prefix + UTF-8 JSON.
; Zero-length frames are legal. The grammar defines the JSON payload only.
;
; Usage:
;   echo '{"type":"auth","id":1,"user":"x","pass":"y"}' | cddl validate --cddl spec/rhp2.cddl --stdin
;
; Provenance: transcribed from Packet.Rhp2 (the pdn codec), pinned against live
; XRouter image 505c + RHPTEST v505d, then compared field-by-field against
; PWP-0222 (June 2023, Paula Dowie G8PZT). Deltas annotated inline below.

; ─── Top-level message choice ─────────────────────────────────────────────────

rhp-message = auth / auth-reply
            / open / open-reply
            / socket / socket-reply
            / bind / bind-reply
            / listen / listen-reply
            / connect / connect-reply
            / send / send-reply
            / sendto / sendto-reply
            / recv
            / accept
            / status / status-reply
            / close / close-reply

; ─── Shared fragments ─────────────────────────────────────────────────────────

; Error codes 0–17 (row 8: 17 is XRouter-observed, not in the published spec)
err-code = 0..17

; Port: XRouter emits a JSON string in DGRAM mode but a JSON number in TRACE
; mode (row 4); the spec's accept example shows a number (row 3). Readers
; normalise both; emitters use string. The grammar accepts both.
port-val = tstr / uint

; Protocol family (open set on the wire — XRouter can grow new families)
pfam = tstr  ; "ax25" / "inet" / "netrom" / "unix" / future

; Socket mode (open set on the wire)
mode = tstr  ; "stream" / "dgram" / "custom" / "seqpkt" / "trace" / "raw" / "semiraw"

; ─── Authentication ───────────────────────────────────────────────────────────

auth = {
  type: "auth",
  ? id: uint,
  user: tstr,
  pass: tstr,
}

auth-reply = {
  type: "authReply",       ; WF-1: capital R on "Reply" (spec field table says "authReply" here, consistent)
  ? id: uint,              ; echoes the request id
  errCode: err-code,       ; WF-1: capital C (spec field tables say lowercase "errcode")
  ? errText: tstr,         ; WF-1: capital T; P-5: spec says mandatory, XRouter omits on some errCode-0 replies
}

; ─── Open (combined create/bind/connect-or-listen) ────────────────────────────

open = {
  type: "open",
  ? id: uint,
  pfam: pfam,
  mode: mode,
  ? port: port-val,        ; P-2: spec says mandatory; XRouter accepts absent
  ? local: tstr,           ; D8: spec says mandatory, XRouter requires it; pdn defaults to node callsign
  ? remote: tstr,          ; spec: "active open only"
  ? flags: uint,           ; P-1: spec says mandatory; absent = 0 (passive)
}

open-reply = {
  type: "openReply",
  ? id: uint,
  ? handle: uint,          ; present on success; absent on parameter errors
  errCode: err-code,
  ? errText: tstr,
}

; ─── Socket / Bind / Listen (the BSD-style passive path) ─────────────────────

socket = {
  type: "socket",
  ? id: uint,
  pfam: pfam,
  mode: mode,
}

socket-reply = {
  type: "socketReply",
  ? id: uint,
  ? handle: uint,          ; present on success; absent on failure
  errCode: err-code,
  ? errText: tstr,
}

bind = {
  type: "bind",
  ? id: uint,
  ? handle: uint,          ; SO-1: not in spec §3.15; XRouter requires it to identify the socket
  local: tstr,
  ? port: port-val,        ; row 14: "0" is a synonym for null = all ports
}

bind-reply = {
  type: "bindReply",
  ? id: uint,
  ? handle: uint,          ; row 12: omitted on parameter errors
  errCode: err-code,
  ? errText: tstr,
}

listen = {
  type: "listen",
  ? id: uint,
  ? handle: uint,          ; SO-2: not in spec §3.17; XRouter requires it to identify the socket
  ? flags: uint,
}

listen-reply = {
  type: "listenReply",
  ? id: uint,
  ? handle: uint,          ; row 12: omitted on parameter errors
  errCode: err-code,       ; row 9: re-listen on same socket → idempotent Ok
  ? errText: tstr,
}

; ─── Connect (separate-step, deferred in pdn but on the wire) ─────────────────

connect = {
  type: "connect",
  ? id: uint,
  ? handle: uint,          ; SO-3: not in spec §3.19; XRouter requires it to identify the socket
  remote: tstr,
}

; row 2: pdn emits "connectReply" (camelCase); the spec's example shows
; "ConnectReply" (a typo). Readers accept both.
connect-reply = {
  type: "connectReply",
  ? id: uint,
  ? handle: uint,
  errCode: err-code,
  ? errText: tstr,
}

; ─── Send (connected stream, or DGRAM-addressed) ─────────────────────────────

send = {
  type: "send",
  ? id: uint,
  ? handle: uint,          ; row 12: absent → errCode 12 "Missing handle"
  data: tstr,              ; row 13: mandatory even when empty; absent → 12
  ? port: port-val,        ; DGRAM mode only
  ? local: tstr,           ; DGRAM mode only (source override)
  ? remote: tstr,          ; DGRAM mode only (destination)
}

send-reply = {
  type: "sendReply",
  ? id: uint,
  ? handle: uint,
  errCode: err-code,
  ? errText: tstr,
  ? status: uint,          ; StatusFlags bits (STREAM mode)
}

; ─── Sendto (explicit-destination datagram) ───────────────────────────────────

; row 5 / RhpMessageType: "sendto" is all-lowercase "to" (the wire-casing trap)
sendto = {
  type: "sendto",
  ? id: uint,
  ? handle: uint,          ; row 12: absent → errCode 12 "Missing handle"
  data: tstr,              ; row 13: mandatory; for custom mode data[0] = PID
  ? port: port-val,        ; P-3: spec says mandatory; XRouter accepts absent when socket is bound
  ? local: tstr,           ; source address override
  ? remote: tstr,          ; P-4: spec says mandatory; spec text implies either local or remote can be absent
  ? tos: uint,             ; type of service (INET only, deferred in pdn)
}

sendto-reply = {
  type: "sendtoReply",     ; all-lowercase "to"
  ? id: uint,
  ? handle: uint,
  errCode: err-code,
  ? errText: tstr,
}

; ─── Recv (async push: data arrived) ─────────────────────────────────────────

; row 6: async pushes carry seqno, never id
recv = {
  type: "recv",
  seqno: uint,             ; row 11: per-connection counter starting at 0
  handle: uint,
  data: tstr,              ; row 7: Latin-1, not base64
  ? port: port-val,        ; row 4: number in TRACE, string in DGRAM
  ? local: tstr,           ; DGRAM: destination address
  ? remote: tstr,          ; DGRAM: source address
  ; TRACE / RAW metadata. The spec's TRACE example (§3.10) shows srce/dest/
  ; ctrl/frametype/rseq/cr/pf. The remaining four (tseq/ilen/pid/ptcl) are
  ; WF-16: XRouter-observed, not in the published spec at all.
  ? action: tstr,          ; "sent" / "rcvd" (spec §3.10)
  ? srce: tstr,            ; source callsign of traced frame (spec §3.10)
  ? dest: tstr,            ; destination callsign of traced frame (spec §3.10)
  ? ctrl: uint,            ; raw AX.25 control byte (spec §3.10)
  ? frametype: tstr,       ; "I" / "RR" / "SABM" etc. (spec §3.10)
  ? rseq: uint,            ; N(R) (spec §3.10)
  ? tseq: uint,            ; N(S) — WF-16: not in spec
  ? cr: tstr,              ; "C" / "R" (spec §3.10)
  ? pf: tstr,              ; "P" / "F" (spec §3.10)
  ? ilen: uint,            ; information field length — WF-16: not in spec
  ? pid: uint,             ; AX.25 PID byte — WF-16: not in spec
  ? ptcl: tstr,            ; decoded L3 protocol name — WF-16: not in spec
}

; ─── Accept (async push: inbound connection on a listener) ────────────────────

; row 15: accept is followed by a status push for the child
accept = {
  type: "accept",
  seqno: uint,             ; row 11: per-connection counter
  handle: uint,            ; the listener's handle
  child: uint,             ; the new child socket's handle
  ? remote: tstr,          ; caller's address
  ? local: tstr,           ; address the caller connected to
  ? port: port-val,        ; row 3: spec shows number, XRouter sends string
}

; ─── Status (request from client, or async push from server) ──────────────────

; As a client request: carries handle, no flags, optional id.
; As a server push: carries handle + flags + seqno, no id.
; The grammar accepts both shapes in one rule.
status = {
  type: "status",
  ? id: uint,              ; present on client requests
  ? seqno: uint,           ; present on server pushes (row 6)
  ? handle: uint,          ; row 12: absent on request → errCode 12
  ? flags: uint,           ; StatusFlags: 1=ConOk, 2=Connected, 4=Busy
}

status-reply = {
  type: "statusReply",
  ? id: uint,
  ? handle: uint,
  errCode: err-code,
  ? errText: tstr,
}

; ─── Close (request from client, or async push from server) ───────────────────

; As a client request: carries handle, optional id.
; As a server push (peer disconnected): carries handle + seqno, no id.
close = {
  type: "close",
  ? id: uint,              ; present on client requests
  ? seqno: uint,           ; present on server pushes (row 6)
  ? handle: uint,          ; row 12: absent on request → errCode 12
}

close-reply = {
  type: "closeReply",
  ? id: uint,
  ? handle: uint,
  errCode: err-code,
  ? errText: tstr,
}
