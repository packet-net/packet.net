# Tooling caches
.idea/
*.swp
.DS_Store
.claude/

# Stryker reports + scratch
artifacts/
StrykerOutput/

# Local node state (used when running the node out of the repo)
.local/
node-data/
*.db
*.db-shm
*.db-wal

# Frontend
web/packetnet-ui/node_modules/
web/packetnet-ui/dist/
web/packetnet-ui/.vite/
web/packetnet-ui/.turbo/
web/packetnet-ui/pnpm-lock.yaml.bak

# Docker
docker/.build-cache/

# LinBPQ runtime artifacts (extracted by the container at startup, not source)
docker/linbpq/HTML/
docker/linbpq/BPQNODES.dat
docker/linbpq/MHSave.txt
docker/linbpq/logs/
docker/linbpq/*.log

# Secrets — never commit
*.pem
!installers/sigstore-pubkey.pem
*.pfx
appsettings.Local.json
appsettings.*.user.json

# Per-developer launch configuration (port choices, env vars)
**/Properties/launchSettings.json

# OS
Thumbs.db
ehthumbs.db

# TypeScript build artefacts for the ax25 web library
web/ax25/dist/


# Generated: the web UI build copied in for the host to serve
